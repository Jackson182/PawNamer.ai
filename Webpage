    function generateName() {
        const personality = document.getElementById('personality').value;
        const result = document.getElementById('result');
        const loader = document.getElementById('loader');
        
        if (!personality) {
            alert("Please tell us a bit about your pet first!");
            return;
        }

        // Show loading state
        result.style.display = 'none';
        loader.style.display = 'block';

        // Simulate AI processing time
        setTimeout(() => {
            loader.style.display = 'none';
            result.style.display = 'block';

            // "AI" logic simulation
            const names = ["Ziggy", "Professor Paws", "Mochi", "Duke", "Bones", "Nebula", "Waffles", "Sir Zoomies"];
            const explanations = [
                "Based on that energetic personality!",
                "Inspired by their regal look.",
                "Because they sound sweet and unique.",
                "Perfect for a pet with such a big presence."
            ];

            const randomName = names[Math.floor(Math.random() * names.length)];
            const randomExpl = explanations[Math.floor(Math.random() * explanations.length)];

            document.getElementById('suggestedName').innerText = randomName;
            document.getElementById('explanation').innerText = randomExpl;
        }, 1500);
